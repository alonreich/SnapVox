<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="snapvox.editor.forms.CustomColorPickerWindow"
        Title="Custom Color"
        Width="350" Height="480"
        Background="#2D2D30"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        RequestedThemeVariant="Dark">
    <StackPanel Margin="20" Spacing="15">
        <TextBlock Text="Select Custom Color" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        
        <ColorPicker Name="Picker" HorizontalAlignment="Center" />
        
        <Button Name="SamplerBtn" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="10" Click="OnSamplerClick">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="󰈋" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center"/>
                <TextBlock Text="Sample Color From Screen" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>
        
        <Grid ColumnDefinitions="*,*" Margin="0,10,0,0">
            <Button Grid.Column="0" Content="OK" Click="OnOkClick" Margin="0,0,5,0" 
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#007ACC" Foreground="White"/>
            <Button Grid.Column="1" Content="Cancel" Click="OnCancelClick" Margin="5,0,0,0"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
        </Grid>
    </StackPanel>
</Window>
