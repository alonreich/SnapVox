<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="snapvox.editor.forms.ResizeWindow"
        Title="Resize Image"
        Width="390" Height="310"
        Background="#2D2D30"
        RequestedThemeVariant="Dark"
        WindowStartupLocation="CenterOwner"
        Topmost="True"
        CanResize="False">
    <StackPanel Margin="20" Spacing="15">
        <Grid ColumnDefinitions="*,Auto" Margin="0,10,0,0">
            <StackPanel Grid.Column="0" Spacing="15">
                <CheckBox Name="RatioCheckbox" Content="Maintain Aspect Ratio" IsChecked="True" Foreground="White" />
                <TextBlock Name="CurrentSizeText" Text="Current: 0 x 0" Foreground="#AAAAAA" FontSize="12" />
                
                <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto" VerticalAlignment="Center">
                    <TextBlock Text="Width:" VerticalAlignment="Center" Foreground="#AAAAAA" Margin="0,0,10,0"/>
                    <TextBox Name="WidthInput" Grid.Column="1" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                    
                    <TextBlock Text="Height:" Grid.Column="2" VerticalAlignment="Center" Foreground="#AAAAAA" Margin="15,0,10,0"/>
                    <TextBox Name="HeightInput" Grid.Column="3" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                </Grid>

                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button Content="50%" Width="58" HorizontalContentAlignment="Center" Click="OnPresetClick" Tag="50"/>
                    <Button Content="100%" Width="58" HorizontalContentAlignment="Center" Click="OnPresetClick" Tag="100"/>
                    <Button Content="200%" Width="58" HorizontalContentAlignment="Center" Click="OnPresetClick" Tag="200"/>
                    <Button Content="Fit" Width="58" HorizontalContentAlignment="Center" Click="OnPresetClick" Tag="Fit"/>
                </StackPanel>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Margin="20,0,0,0" HorizontalAlignment="Center">
                <TextBlock Name="PercentText" Text="100%" HorizontalAlignment="Center" Foreground="White" FontWeight="Bold" Margin="0,0,0,6"/>
                <Slider Name="SizeSlider" Orientation="Vertical" Height="100"
                        Minimum="33" Maximum="300" Value="100" IsVisible="True" 
                        ToolTip.Tip="Scale smoothly from 33% to 300%" />
            </StackPanel>
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
            <Button Name="OkButton" Content="OK" Width="80" HorizontalContentAlignment="Center" Click="OnOkClick" IsDefault="True" Background="#007ACC" Foreground="White"/>
            <Button Content="Cancel" Width="80" HorizontalContentAlignment="Center" Click="OnCancelClick" IsCancel="True" />
        </StackPanel>
    </StackPanel>
</Window>
