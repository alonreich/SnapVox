                                        <Button Classes="toolbar emoji-btn" Content="➡️" Click="OnEmojiSelectClick" Tag="➡️" />
                                        <Button Classes="toolbar emoji-btn" Content="⬅️" Click="OnEmojiSelectClick" Tag="⬅️" />
