                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <ScrollViewer Name="EditorScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <Panel Background="{StaticResource CheckerboardBrush}">
                <Grid Name="MainGrid">
                    <Panel Name="ZoomContainer" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Name="SnipBorder" BorderBrush="#0E2548" BorderThickness="3">
                            <Image Name="EditorImage" Margin="0" Stretch="None">
                                <Image.Effect>
                                    <DropShadowEffect BlurRadius="20" Opacity="0.4" OffsetX="0" OffsetY="10" />
                                </Image.Effect>
                            </Image>
                        </Border>
                        <Canvas Name="AnnotationCanvas" Background="Transparent" 
                                PointerPressed="OnCanvasPointerPressed" 
                                PointerMoved="OnCanvasPointerMoved" 
                                PointerReleased="OnCanvasPointerReleased"
                                ClipToBounds="True">
                                
                            <!-- Contextual Selection Toolbar -->
                            <Border Name="ContextToolbar" IsVisible="False" ZIndex="10001" Background="#DD222222" CornerRadius="4" Padding="4">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Classes="action context-apply" Name="ContextApplyButton" Click="OnContextApplyClick" ToolTip.Tip="Apply (Enter)">
                                    <TextBlock Text="✔" Foreground="#00FF00" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Button>
                                <Rectangle Name="ContextApplySeparator" Width="1" Height="28" Fill="#66555555" VerticalAlignment="Center" />
                                <Button Classes="action context-duplicate" Name="ContextDuplicateButton" Click="OnDuplicateClick" ToolTip.Tip="Duplicate (Ctrl+D)">
                                    <svg:Svg Width="20" Height="20" Path="avares://snapvox.editor/Icons/copy.svg" />
                                </Button>
                                <Rectangle Width="1" Height="28" Fill="#66555555" VerticalAlignment="Center" />
                                <Button Classes="action context-delete" Name="ContextDeleteButton" Click="OnDeleteClick" ToolTip.Tip="Delete (Del) / Cancel (Esc)">
                                    <svg:Svg Width="20" Height="20" Path="avares://snapvox.editor/Icons/delete.svg" />
                                </Button>
                            </StackPanel>
                        </Border>
                        
                        <!-- OCR Selection Toolbar -->
                        <Border Name="OcrContextToolbar" IsVisible="False" ZIndex="10002" Background="#EE222222" BorderBrush="#88FFFFFF" BorderThickness="1.5" CornerRadius="6" Padding="4" BoxShadow="0 4 12 0 #99000000">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Classes="action context-duplicate" Name="OcrContextCopyButton" Click="OnOcrContextCopyClick" ToolTip.Tip="Copy Text (Ctrl+C)" Width="100" Height="36">
                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <svg:Svg Width="18" Height="18" Path="avares://snapvox.editor/Icons/copy.svg" />
                                        <TextBlock Text="Copy Text" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>


                        
                        <!-- Endpoint Handles for Lines/Arrows -->
                        <Canvas Name="StartPointHandle" Width="18" Height="18" IsVisible="False" ZIndex="10002" Cursor="Hand">
                            <Ellipse Width="18" Height="18" Fill="White" />
                            <Ellipse Width="16" Height="16" Margin="1" Stroke="#2E7D32" StrokeThickness="2" />
                            <Ellipse Width="8" Height="8" Margin="5" Fill="#2E7D32" />
                        </Canvas>
                        <Canvas Name="EndPointHandle" Width="18" Height="18" IsVisible="False" ZIndex="10002" Cursor="Hand">
                            <Ellipse Width="18" Height="18" Fill="White" />
                            <Ellipse Width="16" Height="16" Margin="1" Stroke="#007ACC" StrokeThickness="2" />
                            <Ellipse Width="8" Height="8" Margin="5" Fill="#007ACC" />
                        </Canvas>
                    </Canvas>
                    </Panel>

                    <Border Name="NotificationChrome"
                        ClipToBounds="True"/>
                            
                    <!-- Pixelate Strength Slider -->
                    <Slider Name="PixelateSlider" 
                            IsVisible="False" 
                            Orientation="Vertical" 
                            Minimum="2" Maximum="29" 
                            Width="40" 
                            ZIndex="10005"
                            Background="#80000000"
                            Foreground="DeepSkyBlue" />
                </Grid>
            </Panel>
        </ScrollViewer>
    </DockPanel>

    <Grid Name="ClosePromptOverlay" IsVisible="False" ZIndex="100000" Background="#99000000">
        <Border Background="#2D2D30" CornerRadius="8" BorderBrush="#555555" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20">
            <StackPanel Spacing="20">
                <TextBlock Text="Unsaved Changes" FontWeight="Bold" FontSize="18" Foreground="White" />
                <TextBlock Text="You have unsaved modifications. What would you like to do?" Foreground="#AAAAAA" />
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                    <Button Content="Save &amp; Close" Click="OnPromptSaveClose" Background="#007ACC" Foreground="White" Padding="10,5" Cursor="Hand" />
                    <Button Content="Discard" Click="OnPromptDiscard" Background="#D13438" Foreground="White" Padding="10,5" Cursor="Hand" />
                    <Button Content="Cancel" Click="OnPromptCancel" Background="#444444" Foreground="White" Padding="10,5" Cursor="Hand" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
    </Panel>

    <Window.Styles>
        <Style Selector="Border.counter">
            <Setter Property="Background" Value="Red" />
            <Setter Property="CornerRadius" Value="17.5" />
            <Setter Property="Width" Value="35" />
            <Setter Property="Height" Value="35" />
        </Style>
        <Style Selector="Border.counter TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="21" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
    </Window.Styles>
</Window>
