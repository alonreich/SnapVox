<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="snapvox.editor.forms.NotificationOverlayWindow"
        Title="Notification"
        Background="Transparent"
        SystemDecorations="None"
        Topmost="True"
        WindowState="Normal"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        IsHitTestVisible="False"
        SizeToContent="WidthAndHeight">
    <Border Name="NotificationChrome"
            Background="Transparent"
            CornerRadius="14"
            Padding="32,20"
            MinWidth="420"
            BorderBrush="Transparent"
            BorderThickness="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" Opacity="0.75" OffsetX="0" OffsetY="8" />
        </Border.Effect>
        <StackPanel Orientation="Horizontal" Spacing="18" HorizontalAlignment="Center">
            <TextBlock Name="NotificationIcon"
                       Text="&#xE73E;"
                       FontFamily="Segoe MDL2 Assets"
                       Foreground="White"
                       VerticalAlignment="Center"
                       FontSize="46"/>
            <TextBlock Name="NotificationText"
                       Foreground="White"
                       FontSize="35"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="520"/>
        </StackPanel>
    </Border>
</Window>
