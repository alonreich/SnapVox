<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="snapvox.editor.forms.NotificationOverlayWindow"
        Title="Notification"
        Background="Transparent"
        SystemDecorations="None"
        Topmost="True"
        WindowState="Normal"
        WindowStartupLocation="Manual"
        ShowInTaskbar="False"
        IsHitTestVisible="False"
        SizeToContent="WidthAndHeight">
    <Border Name="NotificationChrome"
            Background="Transparent"
            CornerRadius="8"
            Padding="18,10"
            MinWidth="220"
            BorderBrush="Transparent"
            BorderThickness="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" Opacity="0.35" OffsetX="0" OffsetY="4" />
        </Border.Effect>
        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
            <TextBlock Name="NotificationIcon"
                       Text="&#xE73E;"
                       FontFamily="Segoe MDL2 Assets"
                       Foreground="White"
                       VerticalAlignment="Center"
                       FontSize="28"/>
            <TextBlock Name="NotificationText"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="360"/>
        </StackPanel>
    </Border>
</Window>
