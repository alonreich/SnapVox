<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="snapvox.forms.CaptureWindow"
        Title="Capture Selection"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        SystemDecorations="None"
        Topmost="True"
        WindowState="Normal"
        CanResize="False"
        ShowInTaskbar="False"
        Focusable="True"
        Cursor="Cross">
    <Canvas Name="MainCanvas" Background="#01000000" PointerPressed="OnPointerPressed" PointerMoved="OnPointerMoved" PointerReleased="OnPointerReleased">
        <Image Name="BackgroundImage" Stretch="None" IsHitTestVisible="False" Opacity="1.0" />
        <Border Name="HighlightBorder" BorderBrush="#007ACC" BorderThickness="3" Background="#33007ACC" IsVisible="False" IsHitTestVisible="False" />
        <Border Name="Rubberband" BorderBrush="#007ACC" BorderThickness="2" Background="#22007ACC" IsVisible="False" IsHitTestVisible="False" />
        
        <Border Name="DimensionBadge" Background="#CC1E1E1E" CornerRadius="4" Padding="6,2" BorderBrush="#007ACC" BorderThickness="1" IsVisible="False" IsHitTestVisible="False">
            <TextBlock Name="DimensionText" Text="0 x 0" Foreground="White" FontSize="11" FontWeight="Bold"/>
        </Border>

        <Border Name="WindowSnapBadge" Background="#DD007ACC" CornerRadius="4" Padding="8,3" BorderBrush="White" BorderThickness="1" IsVisible="False" IsHitTestVisible="False">
            <TextBlock Text="Window selected" Foreground="White" FontSize="11" FontWeight="Bold"/>
        </Border>

        <Border Name="InstructionBorder" Background="#CC1E1E1E" CornerRadius="20" Padding="12,6" BorderBrush="#444444" BorderThickness="1" IsHitTestVisible="False">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Name="InstructionText" Text="Drag to capture or hover window" Foreground="#AAAAAA" FontSize="11"/>
                <TextBlock Name="OcrText" Text="T = Text capture" Foreground="#AAAAAA" FontSize="11"/>
                <TextBlock Text="Esc = Cancel" Foreground="#AAAAAA" FontSize="11"/>
            </StackPanel>
        </Border>

        <Border Name="OcrProcessingStatus" Background="#EE1E1E1E" CornerRadius="4" Padding="12,8" BorderBrush="#007ACC" BorderThickness="1" IsVisible="False" IsHitTestVisible="False">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <ProgressBar IsIndeterminate="True" Width="16" Height="16" Theme="{StaticResource {x:Type ProgressBar}}"/>
                <TextBlock Text="Processing OCR..." Foreground="White" VerticalAlignment="Center" FontSize="12"/>
            </StackPanel>
        </Border>

        <Border Name="MagnifierPanel" Width="160" Height="160" CornerRadius="80" BorderBrush="#007ACC" BorderThickness="3" Background="Black" IsVisible="False" IsHitTestVisible="False" ClipToBounds="True">
            <Canvas Width="160" Height="160">
                <Image Name="MagnifierImage" Stretch="None" IsHitTestVisible="False" />
                <Ellipse Width="154" Height="154" Margin="3,3,0,0" Stroke="White" StrokeThickness="1" Fill="Transparent" />
                <Path Data="M 80 0 L 80 160 M 0 80 L 160 80" Stroke="#55007ACC" StrokeThickness="1" />
                <Ellipse Width="10" Height="10" Margin="75,75,0,0" Fill="#88007ACC" />
            </Canvas>
        </Border>
    </Canvas>
</Window>
